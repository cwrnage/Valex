<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="Valex.GithubWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:Valex" Title="github" Width="300" Height="176" AllowsTransparency="True" Background="#00FFFFFF" ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True" WindowStartupLocation="CenterScreen" WindowStyle="None">
  <Grid ClipToBounds="True">
    <Panel.Background>
      <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Offset="0" Color="#202020" />
        <GradientStop Offset="1" Color="#FF060203" />
      </LinearGradientBrush>
    </Panel.Background>
    <Button Name="Save" Width="54" Height="28" Margin="0,0,13,13" HorizontalAlignment="Right" VerticalAlignment="Bottom" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="#88303030" BorderThickness="0" Content="Save" FontFamily="/Valex;component/Assets/Fonts/#Manrope SemiBold" Foreground="#909090" Style="{DynamicResource FlatButton}" Click="ButtonHandler">
      <UIElement.Effect>
        <DropShadowEffect BlurRadius="0" ShadowDepth="0" Color="#303030" />
      </UIElement.Effect>
    </Button>
    <Button Name="Cancel" Width="72" Height="28" Margin="0,0,78,13" HorizontalAlignment="Right" VerticalAlignment="Bottom" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="#88303030" BorderThickness="0" Content="Cancel" FontFamily="/Valex;component/Assets/Fonts/#Manrope SemiBold" Foreground="#909090" Style="{DynamicResource FlatButton}" Click="ButtonHandler">
      <UIElement.Effect>
        <DropShadowEffect BlurRadius="0" ShadowDepth="0" Color="#303030" />
      </UIElement.Effect>
    </Button>
    <Label Width="119" Height="24" Margin="14,9,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Github User:" FontFamily="Consolas" Foreground="#909090" Opacity="1" />
    <TextBox Name="userbox" Margin="14,33,13,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="#77303030" BorderThickness="0" FontFamily="Consolas" Foreground="#999999" Text="" TextWrapping="NoWrap" Height="24" VerticalAlignment="Top">
      <FrameworkElement.Resources>
        <ResourceDictionary>
          <Style x:Key="{x:Type Border}" TargetType="{x:Type Border}">
            <Setter Property="Border.CornerRadius" Value="2" />
          </Style>
        </ResourceDictionary>
      </FrameworkElement.Resources>
    </TextBox>
    <Label Width="160" Height="24" Margin="14,64,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Personal Access Token:" FontFamily="Consolas" Foreground="#909090" Opacity="1" />
    <TextBox Name="patbox" Margin="14,88,13,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="#77303030" BorderThickness="0" FontFamily="Consolas" Foreground="#999999" Text="" TextWrapping="NoWrap" Height="24" VerticalAlignment="Top">
      <FrameworkElement.Resources>
        <ResourceDictionary>
          <Style x:Key="{x:Type Border}" TargetType="{x:Type Border}">
            <Setter Property="Border.CornerRadius" Value="2" />
          </Style>
        </ResourceDictionary>
      </FrameworkElement.Resources>
    </TextBox>
  </Grid>
</Window>