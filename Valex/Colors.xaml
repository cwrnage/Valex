<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="Color.WindowBackground">#FF090909</Color>
    <Color x:Key="Color.ButtonBackground">#FF100D0D</Color>
    <Color x:Key="Color.IconLight">#FFC3C3C3</Color>
    <Color x:Key="Color.IconDark">#FF6D6D6D</Color>
    <Color x:Key="Color.Accent">#FFB58D8D</Color>
    <Color x:Key="Color.Status">#FFE56F7B</Color>
    <Color x:Key="Color.StatusStroke">#FFA09E9F</Color>
    <Color x:Key="Color.TransparentButton">#FFDDDDDD</Color>
    <Color x:Key="Color.TextSecondary">#FF737373</Color>
    <Color x:Key="Color.Gradient1">#FF231818</Color>
    <Color x:Key="Color.Gradient2">#FF221111</Color>
    <Color x:Key="Color.Gradient3">#FF101010</Color>
    <Color x:Key="Color.Gradient4">#FF171717</Color>
    <Color x:Key="Color.Gradient5">#FF131313</Color>
    <Color x:Key="Color.Gradient6">#FF4B3737</Color>
    <Color x:Key="Color.Gradient7">#FF452D2D</Color>
    <Color x:Key="Color.Gradient8">#FF282828</Color>
    <Color x:Key="Color.Gradient9">#FF1A1818</Color>
    <Color x:Key="Color.Gradient10">#FF0F0C0C</Color>
    <Color x:Key="Color.Gradient11">#FF1F1F1F</Color>
    <Color x:Key="Color.Gradient12">#FF110F0F</Color>
    <Color x:Key="Color.Gradient13">#FF404040</Color>
    <Color x:Key="Color.Gradient14">#FF1B1B1B</Color>
    <Color x:Key="Color.Border1">#FF424242</Color>
    <Color x:Key="Color.TextBoxForeground">#FF525252</Color>
    <Color x:Key="Color.TextTertiary">#FFA19F9F</Color>
    <Color x:Key="Color.ButtonDark">#FF232323</Color>
    <Color x:Key="Color.Border2">#FF242424</Color>
    <Color x:Key="Color.MenuBackground">#FF110D0D</Color>
    <Color x:Key="Color.KeyFormBackground">#FF0B0909</Color>
    <Color x:Key="Color.KeyFormBorder">#FF222222</Color>
    <Color x:Key="Color.Alert">#FFA52828</Color>
    <Color x:Key="Color.AlertText">#FFC7BBBB</Color>
    <Color x:Key="Color.Accent2">#FFCE7272</Color>
    <Color x:Key="Color.Border3">#FFA6A6A6</Color>
    <Color x:Key="Color.ButtonGray">#232323</Color>
    <Color x:Key="Color.Black">Black</Color>
    <Color x:Key="Color.White">White</Color>

    <SolidColorBrush x:Key="Brush.WindowBackground" Color="{StaticResource Color.WindowBackground}" />
    <SolidColorBrush x:Key="Brush.ButtonBackground" Color="{StaticResource Color.ButtonBackground}" />
    <SolidColorBrush x:Key="Brush.IconLight" Color="{StaticResource Color.IconLight}" />
    <SolidColorBrush x:Key="Brush.IconDark" Color="{StaticResource Color.IconDark}" />
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.Status" Color="{StaticResource Color.Status}" />
    <SolidColorBrush x:Key="Brush.StatusStroke" Color="{StaticResource Color.StatusStroke}" />
    <SolidColorBrush x:Key="Brush.TransparentButton" Color="{StaticResource Color.TransparentButton}" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.TextTertiary" Color="{StaticResource Color.TextTertiary}" />
    <SolidColorBrush x:Key="Brush.TextBoxForeground" Color="{StaticResource Color.TextBoxForeground}" />
    <SolidColorBrush x:Key="Brush.ButtonDark" Color="{StaticResource Color.ButtonDark}" />
    <SolidColorBrush x:Key="Brush.Border1" Color="{StaticResource Color.Border1}" />
    <SolidColorBrush x:Key="Brush.Border2" Color="{StaticResource Color.Border2}" />
    <SolidColorBrush x:Key="Brush.MenuBackground" Color="{StaticResource Color.MenuBackground}" />
    <SolidColorBrush x:Key="Brush.KeyFormBackground" Color="{StaticResource Color.KeyFormBackground}" />
    <SolidColorBrush x:Key="Brush.KeyFormBorder" Color="{StaticResource Color.KeyFormBorder}" />
    <SolidColorBrush x:Key="Brush.Alert" Color="{StaticResource Color.Alert}" />
    <SolidColorBrush x:Key="Brush.AlertText" Color="{StaticResource Color.AlertText}" />
    <SolidColorBrush x:Key="Brush.Accent2" Color="{StaticResource Color.Accent2}" />
    <SolidColorBrush x:Key="Brush.Border3" Color="{StaticResource Color.Border3}" />
    <SolidColorBrush x:Key="Brush.ButtonGray" Color="{StaticResource Color.ButtonGray}" />
    <SolidColorBrush x:Key="Brush.Black" Color="{StaticResource Color.Black}" />
    <SolidColorBrush x:Key="Brush.White" Color="{StaticResource Color.White}" />

</ResourceDictionary>