<Application x:Class="Valex.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Valex;component/Colors.xaml" />

                <ResourceDictionary Source="/Valex;component/Style.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="ScrollBarThumbHorizontal2" TargetType="{x:Type Thumb}">
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>